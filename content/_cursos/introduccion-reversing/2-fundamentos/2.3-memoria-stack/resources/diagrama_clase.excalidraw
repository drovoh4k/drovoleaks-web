      "text": "CALLING CONVENTION",
      "fontSize": 51.45164997966221,
      "fontFamily": 7,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CALLING CONVENTION",
      "autoResize": true,
      "lineHeight": 1.15,
      "hasTextLink": false
    },
    {
      "id": "nvG8t4Dxo3vfKfzFZOqDQ",
      "type": "text",
      "x": 9027.876376572181,
      "y": 227.28285413832896,
      "width": 785.399658203125,
      "height": 70,
      "angle": 0,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "YjohcLwTYetkuWlG9-0RN"
      ],
      "frameId": null,
      "index": "bMr",
      "roundness": null,
      "seed": 436146444,
      "version": 736,
      "versionNonce": 1369243444,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772530860336,
      "link": null,
      "locked": false,
      "text": "Una calling convention es un conjunto de reglas que\ndefinen cómo una función interactúa con su caller.",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "right",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Una calling convention es un conjunto de reglas que\ndefinen cómo una función interactúa con su caller.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D9Mxodj-_aCIMTqg1C3z4",
      "type": "text",
      "x": 9226.8243135839,
      "y": 376.0122501459455,
      "width": 387.5037841796875,
      "height": 41.4,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "kq9CI13GLenUQ1-vt6N_O",
        "09z3qdF1pgvBgcZeBaSGQ",
        "C7x4y7FRZWKqqtI0x74Z-"
      ],
      "frameId": null,
      "index": "bN3",
      "roundness": null,
      "seed": 1096291636,
      "version": 3024,
      "versionNonce": 1772026036,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772530860336,
      "link": null,
      "locked": false,
      "text": "Por ejemplo:  cdecl 32-bit",
      "fontSize": 36,
      "fontFamily": 7,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Por ejemplo:  cdecl 32-bit",
