      "isDeleted": true,
      "boundElements": null,
      "updated": 1775298720988,
      "link": null,
      "locked": false,
      "text": "El programa debe indicar exactamente qué\nacción quiere que el Kernel realice.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "El programa debe indicar exactamente qué acción quiere que el Kernel realice.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "e7B6qevTPq10H45o0mrzx",
      "type": "text",
      "x": 4784.025810891683,
      "y": 1050.1231169065832,
      "width": 694.583740234375,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b77",
      "roundness": null,
      "seed": 935040312,
      "version": 3,
      "versionNonce": 869377848,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1775298722570,
      "link": null,
      "locked": false,
      "text": "El programa debe indicar exactamente qué\nacción quiere que el Kernel realice.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "El programa debe indicar exactamente qué acción quiere que el Kernel realice.",
