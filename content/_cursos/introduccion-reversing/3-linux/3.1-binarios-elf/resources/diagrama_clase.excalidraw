      "type": "text",
      "x": 4732.388527275956,
      "y": 581.5222583974809,
      "width": 710.738715615257,
      "height": 50.029624011710254,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
