      "link": null,
      "locked": false,
      "text": "Es el \"trampolín\".",
      "fontSize": 20.0118496046841,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Es el \"trampolín\".",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "URDsI4zY1KtCqtyfLnRr5",
      "type": "text",
      "x": 4030.51233592017,
      "y": 1197.8218084598504,
      "width": 440.93327407983145,
      "height": 50.029624011710254,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "DRROzrLNBKaDO2auXNHX2",
        "BFYn04Lp1BBbc9tYqBS7d"
      ],
      "frameId": null,
      "index": "b5g",
