    {
      "id": "Mliy9xXTgocIZTu_aqO3p",
      "type": "text",
      "x": 3329.471693545793,
      "y": 898.8395739084068,
      "width": 101.85086059570312,
      "height": 25.014812005855127,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
