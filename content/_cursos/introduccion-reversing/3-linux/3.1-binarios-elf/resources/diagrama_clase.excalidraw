      "versionNonce": 1314532664,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775300350670,
      "link": null,
      "locked": false,
      "text": "Todo programa, sin importar su tamaño o complejidad, se carga sin privilegios,\nconcretamente en Userland (Ring 3), un entorno restringido.",
      "fontSize": 20.0118496046841,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Todo programa, sin importar su tamaño o complejidad, se carga sin privilegios, concretamente en Userland (Ring 3), un entorno restringido.",
      "autoResize": false,
      "lineHeight": 1.25
    },
