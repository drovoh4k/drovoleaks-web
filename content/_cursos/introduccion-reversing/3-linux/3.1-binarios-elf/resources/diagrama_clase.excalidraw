      "versionNonce": 977517624,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775300350670,
      "link": null,
      "locked": false,
      "text": "El programa indica la acción (Syscall ID) en un registro.",
      "fontSize": 20.0118496046841,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "El programa indica la acción (Syscall ID) en un registro.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "8nTOmQxZDpBJZiZDmwBvk",
      "type": "text",
      "x": 4771.2383212685645,
      "y": 948.010603174705,
      "width": 633.0391281892622,
      "height": 25.014812005855127,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "-bXyNgQmf3yWJISW8WA3U"
      ],
      "frameId": null,
      "index": "b79",
      "roundness": null,
      "seed": 63830856,
      "version": 3385,
      "versionNonce": 334460216,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775300350670,
      "link": null,
      "locked": false,
      "text": "El proceso se divide en 3 fases:",
      "fontSize": 20.0118496046841,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "El proceso se divide en 3 fases:",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "zy09gqD2lRAVIdOWdGCw8",
      "type": "text",
      "x": 4743.583401760539,
      "y": 1073.3816063498616,
      "width": 688.3489658569295,
