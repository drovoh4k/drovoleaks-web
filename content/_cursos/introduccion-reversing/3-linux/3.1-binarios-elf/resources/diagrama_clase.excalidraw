      "versionNonce": 429054792,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775296813192,
      "link": null,
      "locked": false,
      "text": "Son pequeñas rutinas de código ejecutable\nsituadas en el segmento de texto (sección .plt)",
      "fontSize": 20.0118496046841,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Son pequeñas rutinas de código ejecutable situadas en el segmento de texto (sección .plt)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "qANyH1QySc6xazhTCOL-9",
      "type": "text",
      "x": 4030.5123356974736,
      "y": 1260.4931756473504,
      "width": 440.93327430252566,
      "height": 50.029624011710254,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
