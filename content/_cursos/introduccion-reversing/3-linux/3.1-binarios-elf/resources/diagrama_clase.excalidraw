      "versionNonce": 794092344,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775300350670,
      "locked": false,
      "text": "1. Preparación de la petición",
      "fontSize": 28,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Preparación de la petición",
      "autoResize": true,
      "lineHeight": 1.15,
      "hasTextLink": false,
      "link": null
    },
    {
      "id": "Qkmn0x-qxjAIFgjT8rLRr",
