      "type": "text",
      "x": 3665.9837985982076,
      "y": 800.8034698505994,
      "width": 694.583740234375,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
