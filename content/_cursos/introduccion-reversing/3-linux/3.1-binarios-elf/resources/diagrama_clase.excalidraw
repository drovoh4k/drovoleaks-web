      "updated": 1775296813192,
      "link": null,
      "locked": false,
      "text": "Su función es almacenar las direcciones reales y\nabsolutas de las funciones externas en memoria.",
      "fontSize": 20.0118496046841,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Su función es almacenar las direcciones reales y absolutas de las funciones externas en memoria.",
