      "versionNonce": 297537080,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775300350670,
      "link": null,
      "locked": false,
      "text": "Coloca los parámetros en registros específicos siguiendo un orden definido.",
      "fontSize": 20.0118496046841,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Coloca los parámetros en registros específicos siguiendo un orden definido.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
