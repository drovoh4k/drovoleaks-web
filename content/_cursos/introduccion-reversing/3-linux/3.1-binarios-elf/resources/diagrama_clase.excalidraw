      "isDeleted": false,
      "boundElements": [],
      "updated": 1775296813192,
      "link": null,
      "locked": false,
      "text": "Tu binario nunca llama a la función externa\ndirectamente, llama a este trampolín.",
      "fontSize": 20.0118496046841,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Tu binario nunca llama a la función externa directamente, llama a este trampolín.",
      "autoResize": false,
      "lineHeight": 1.25
    },
