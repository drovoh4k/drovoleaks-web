---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
{%- assign all = site.writeups | concat: site.cursos | concat: site.masterclass | concat: site.vulnerabilidades | concat: site.varios | concat: site.papers -%}
{%- assign items = all | where_exp: "i", "i.draft != true" | sort: "date" | reverse -%}
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description | strip_newlines | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/feed.xml' | absolute_url }}</id>
  <author><name>{{ site.author.name }}</name><uri>{{ site.author.youtube }}</uri></author>
  {%- for it in items limit: 50 %}
  <entry>
    <title>{{ it.title | xml_escape }}</title>
    <link href="{{ it.url | absolute_url }}" rel="alternate" type="text/html"/>
    <published>{{ it.date | date_to_xmlschema }}</published>
    <updated>{{ it.date | date_to_xmlschema }}</updated>
    <id>{{ it.url | absolute_url }}</id>
    <category term="{{ it.categoria_slug | xml_escape }}"/>
    {%- for t in it.tags %}
    <category term="{{ t | xml_escape }}"/>
    {%- endfor %}
    {%- if it.descripcion %}
    <summary>{{ it.descripcion | xml_escape }}</summary>
    {%- endif %}
    {%- if it.video %}
    <link href="{{ it.video }}" rel="related" type="text/html" title="Vídeo"/>
    {%- endif %}
  </entry>
  {%- endfor %}
</feed>
